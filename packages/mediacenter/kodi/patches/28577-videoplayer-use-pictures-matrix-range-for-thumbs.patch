From 597ebf52b61f577806a8ec20e13de6b3ecb198e0 Mon Sep 17 00:00:00 2001
From: reardonia <2925104+reardonia@users.noreply.github.com>
Date: Thu, 9 Jul 2026 11:38:49 -0400
Subject: [PATCH 1/4] VideoPlayer: use the picture's matrix and range for
 extracted thumbs

ExtractThumbToTexture converted every decoded frame with swscale's
default BT.601 matrix and assumed limited range. Feed the decoded
picture's colorspace and range through sws_setColorspaceDetails,
as CRendererSoftware already does. BT.709 and BT.2020 sources stop
shifting hue in saturated colors and full-range sources are no
longer expanded a second time.
---
 xbmc/cores/VideoPlayer/DVDFileInfo.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/xbmc/cores/VideoPlayer/DVDFileInfo.cpp b/xbmc/cores/VideoPlayer/DVDFileInfo.cpp
index 74214f39ee48d..1ccfd81b38308 100644
--- a/xbmc/cores/VideoPlayer/DVDFileInfo.cpp
+++ b/xbmc/cores/VideoPlayer/DVDFileInfo.cpp
@@ -227,6 +227,10 @@ std::unique_ptr<CTexture> CDVDFileInfo::ExtractThumbToTexture(const CFileItem& f
 
           if (context)
           {
+            // dstRange is ignored for RGB destinations; the tables drive YUV->RGB
+            sws_setColorspaceDetails(context, sws_getCoefficients(picture.color_space),
+                                     picture.color_range == 1 ? 1 : 0,
+                                     sws_getCoefficients(AVCOL_SPC_BT709), 1, 0, 1 << 16, 1 << 16);
             uint8_t* planes[YuvImage::MAX_PLANES];
             int stride[YuvImage::MAX_PLANES];
             picture.videoBuffer->GetPlanes(planes);

From 7e26b361e5c2afa51e48d9eff3c40ed39b59975a Mon Sep 17 00:00:00 2001
